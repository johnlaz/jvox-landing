{
  "name": "jvox-analytics",
  "main": "src/index.js",
  "compatibility_date": "2024-12-19",
  
  "env": {
    "production": {
      "vars": {
        "STATS_SECRET": "lazlab2025secure"
      }
    }
  },

  "kv_namespaces": [
    {
      "binding": "JVOX_ANALYTICS",
      "id": "YOUR_KV_NAMESPACE_ID",
      "preview_id": "YOUR_KV_NAMESPACE_ID"
    }
  ]
}
